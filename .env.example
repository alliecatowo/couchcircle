# ── CouchCircle env ──────────────────────────────────────────────────────────
# Copy to `.env` for local dev. Everything here is non-secret config; there are
# NO secrets in this repo (rooms are ephemeral, no accounts, no API keys).

# Where the browser reaches the PartyKit realtime server.
# Local dev: the `dev:party` script serves on 127.0.0.1:1999.
# Production: your deployed PartyKit host, e.g. couchcircle.<you>.partykit.dev
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999

# ── PartyKit-side vars (set on the PartyKit deploy, NOT the Next.js build) ─────
# These are read from the party environment (room.env). Set them with
# `partykit deploy --var ALLOWED_ORIGINS=...` or partykit.json#vars.

# Comma-separated CORS allowlist for the lobby (couch-code create/resolve).
# REQUIRED in production — when unset the lobby falls back to a permissive
# dev mode (localhost + echoes any origin) so two-tab local testing works.
# In production set this to your exact frontend origin(s); a request Origin is
# reflected ONLY when it matches. Wildcards are never used.
#   ALLOWED_ORIGINS=https://couchcircle.app,https://www.couchcircle.app
# ALLOWED_ORIGINS=
